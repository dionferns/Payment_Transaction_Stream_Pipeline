{
  "name": "s3-sink-transactions",
  "config": {
    "connector.class": "io.confluent.connect.s3.S3SinkConnector",
    "tasks.max": "1",

    "topics": "payment.transactions.raw",

    "s3.region": "us-east-1",
    "s3.bucket.name": "pipeline-data",
    "store.url": "http://minio:9000",
    "storage.class": "io.confluent.connect.s3.storage.S3Storage",
    "s3.credentials.provider.class": "com.amazonaws.auth.EnvironmentVariableCredentialsProvider",

    "format.class": "io.confluent.connect.s3.format.json.JsonFormat",
    "flush.size": "500",
    "rotate.interval.ms": "300000",

    "topics.dir": "landing/transactions",
    "path.format": "'date='yyyy-MM-dd/'hour='HH",
    "locale": "en_US",
    "timezone": "UTC",
    "timestamp.extractor": "RecordField",
    "timestamp.field": "timestamp"
  }
}
