# =============================================================================
# Payment Stream Pipeline — Environment Configuration
# Copy to .env and populate before running locally or in Docker.
# Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Spark
# ---------------------------------------------------------------------------
SPARK_MASTER=spark://spark-master:7077
SPARK_APP_NAME=payment-stream-pipeline
SPARK_EXECUTOR_MEMORY=2g
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_CORES=2

# ---------------------------------------------------------------------------
# Airflow
# ---------------------------------------------------------------------------
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__WEBSERVER__SECRET_KEY=
AIRFLOW_UID=50000

# ---------------------------------------------------------------------------
# Storage Paths
# ---------------------------------------------------------------------------
LANDING_ZONE_PATH=./data/landing
PROCESSED_ZONE_PATH=./data/processed
ANALYTICS_ZONE_PATH=./data/analytics
QUALITY_RESULTS_PATH=./data/quality
SEEDS_PATH=./data/seeds

# ---------------------------------------------------------------------------
# Kafka (optional — pipeline falls back to file-based landing zone if unset)
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC_TRANSACTIONS=payment.transactions.raw
KAFKA_CONSUMER_GROUP=payment-stream-pipeline

# ---------------------------------------------------------------------------
# Transaction Generator
# ---------------------------------------------------------------------------
GENERATOR_TPS=1000
GENERATOR_DURATION_SECONDS=3600
GENERATOR_OUTPUT_MODE=file         # file | kafka
GENERATOR_BATCH_SIZE=500           # records flushed per write

# ---------------------------------------------------------------------------
# Pipeline Thresholds
# ---------------------------------------------------------------------------
FRAUD_VELOCITY_WINDOW_SECONDS=60
FRAUD_VELOCITY_MAX_TXN=5
FRAUD_AMOUNT_MULTIPLIER=3.0
FRAUD_GEO_WINDOW_MINUTES=30
CHARGEBACK_RATIO_THRESHOLD=0.02    # 2% chargeback rate flags a merchant

# ---------------------------------------------------------------------------
# Alerting
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
ALERT_EMAIL=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json                     # json | text
